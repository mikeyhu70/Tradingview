//@version=5
indicator('Price and Date Forecast (2024 V3 DEBUG)', overlay=true,max_bars_back=5000)


// Input parameters
length1 = input.int(68, title='Dominant Cycle Length #1', minval=1)
length2 = input.int(34, title='Dominant Cycle Length #2', minval=1)
length3 = input.int(17, title='Dominant Cycle Length #3', minval=1)
leftBars = input.int(8, "Left Bars to get Pivot High/Low", minval=1)
rightBars = input.int(8, "Right Bars to get Pivot High/Low", minval=1)
kp = input(5, title="Candlestick Matching Pattern Length")
td = input.bool(false, title="TD demark flip setup? (if not contineous bar patten in kp length)")
td_trend = input.bool(false, title="TD demark trend flip setup? (all firs bars vs last bar logic)")
lookback = input.int(4, "TD Demark Lookback Flip Bars", minval=4)
y = input.int(5000, title='Lookback Bars', maxval=5000)
forecast_periods = input.int(10, title='Number of Periods to Forecast', minval=1)
_debug = input.bool(true, title="Show debug information?")

price = input.source(hl2)

bb_length = input.int(20, title='Bollinger Bands Length', minval=1)
bb_stddev = input.float(2.0, title='Bollinger Bands Standard Deviation', minval=0.1, step=0.1)
kc_length = input.int(20, title='Keltner Channel Length', minval=1)
kc_mult = input.float(1.0, title='Keltner Channel Multiplier', minval=0.1, step=0.1)
volatility_length = input.int(20, title="Volatility Length") // Adjust the length as needed


// Calculate the dominant cycle using time series analysis
//price = close
//cycle = ta.sma(price, cycle_length)

txt_col_price = input.color(color.rgb(208, 227, 62), 'Text/Frame Color', group='Dashboard')
txt_col_price_adj = input.color(color.rgb(231, 37, 237), 'Text/Frame Color', group='Dashboard')
txt_col_date = input.color(color.rgb(48, 228, 241), 'Text/Frame Color', group='Dashboard')
txt_col_pattern = input.color(color.rgb(238, 232, 166), 'Text/Frame Color', group='Dashboard')
txt_col = input.color(color.rgb(182, 186, 200), 'Text/Frame Color', group='Dashboard')
dash_loc = input.string('Mid Right', 'Dashboard Location', options=['Top Right', 'Bottom Right', 'Top Left', 'Mid Left', 'Mid Right'], group='Dashboard')
text_size = input.string('Tiny', 'Dashboard Size', options=['Tiny', 'Small', 'Normal', 'Large'], group='Dashboard')
debugtext_size = input.string('Tiny', 'Debug Dashboard Size', options=['Tiny', 'Small', 'Normal', 'Large'], group='Dashboard')
debugdash_loc = input.string('Bottom Center', 'Debug Dashboard Location', options=['Top Left', 'Top Center', 'Top Right', 'Mid Left', 'Mid Center', ' Mid Right', 'Bottom Left', 'Bottom Center', 'Bottom Right'], group='Dashboard')

// ****************************************************

// Goertzel algorithm to detect the dominant cycle
goertzel(price, length) =>
    k = 0.0
    w = 2 * math.pi / length
    cosine = math.cos(w)
    sine = math.sin(w)
    coeff = 2 * cosine
    q0 = 0.0
    q1 = 0.0
    q2 = 0.0
    for i = 0 to length - 1
        q0 := coeff * q1 - q2 + price[i]
        q2 := q1
        q1 := q0
    real = (q1 - q2 * cosine)
    imag = (q2 * sine)
    magnitude = math.sqrt(real * real + imag * imag)
    [real, imag, magnitude]

