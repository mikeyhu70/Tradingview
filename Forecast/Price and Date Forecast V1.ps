var table_position = dash_loc == 'Top Left' ? position.top_left : dash_loc == 'Bottom Left' ? position.bottom_left : dash_loc == 'Top Right' ? position.top_right : dash_loc == 'Mid Left' ? position.middle_left : dash_loc == 'Mid Right' ? position.middle_right : position.bottom_right
var table_text_size = text_size == 'Tiny' ? size.tiny : text_size == 'Small' ? size.small : text_size == 'Normal' ? size.normal : size.large

// Create a table to display the forecasted prices and dates
var table forecast_table = table.new(table_position, 2, forecast_periods + 1, border_width=1, border_color=txt_col,frame_color=txt_col,frame_width=1)

// Add table headers
//table.cell(forecast_table, 0, 0, 'Period', text_color=txt_col, text_size=table_text_size)
table.cell(forecast_table, 0, 0, 'Price', text_color=txt_col, text_size=table_text_size)
table.cell(forecast_table, 1, 0, 'Date', text_color=txt_col, text_size=table_text_size)

// Populate the table with forecasted prices and dates
for i = 1 to forecast_periods by 1
    forecast_price_value = forecast_price(i)
    forecast_date_value = forecast_date(i)
    //table.cell(forecast_table, 0, i, str.tostring(i), text_color=txt_col, text_size=table_text_size)
    table.cell(forecast_table, 0, i, str.tostring(forecast_price_value, '#.##'), text_color=txt_col_price, text_size=table_text_size)
    table.cell(forecast_table, 1, i, str.format("{0,date,yyyy-MM-dd}", forecast_date_value), text_color=txt_col_date, text_size=table_text_size)


