//@version=5
indicator('Price and Date Forecast (2024 V1)', overlay=true)

// Input parameters
cycle_length = input.int(12, title='Dominant Cycle Length', minval=1)
forecast_periods = input.int(10, title='Number of Periods to Forecast', minval=1)
price = input.source(hl2)

// Calculate the dominant cycle using time series analysis
//price = close
//cycle = ta.sma(price, cycle_length)

txt_col_price = input.color(color.rgb(208, 227, 62), 'Text/Frame Color', group='Dashboard')
txt_col_date = input.color(color.rgb(48, 228, 241), 'Text/Frame Color', group='Dashboard')
txt_col_pattern = input.color(color.rgb(238, 232, 166), 'Text/Frame Color', group='Dashboard')
txt_col = input.color(color.rgb(182, 186, 200), 'Text/Frame Color', group='Dashboard')
dash_loc = input.string('Mid Right', 'Dashboard Location', options=['Top Right', 'Bottom Right', 'Top Left', 'Mid Left', 'Mid Right'], group='Dashboard')
text_size = input.string('Tiny', 'Dashboard Size', options=['Tiny', 'Small', 'Normal', 'Large'], group='Dashboard')


// Goertzel algorithm to detect the dominant cycle
goertzel(price, length) =>
    k = 0.0
    w = 2 * math.pi / length
    cosine = math.cos(w)
    sine = math.sin(w)
    coeff = 2 * cosine
    q0 = 0.0
    q1 = 0.0
    q2 = 0.0
    for i = 0 to length - 1
        q0 := coeff * q1 - q2 + price[i]
        q2 := q1
        q1 := q0
    real = (q1 - q2 * cosine)
    imag = (q2 * sine)
    magnitude = math.sqrt(real * real + imag * imag)
    [real, imag, magnitude]

// Calculate the dominant cycle using Goertzel algorithm
//[real, imag, cycle] = goertzel(price, cycle_length)

// Convert cycle to integer
cycle_int = int(cycle_length)

//forecast_price(periods) =>
//    [real, imag, magnitude] = goertzel(price, cycle_length)
//    phase = math.atan(imag/ real)
//    amplitude = magnitude / 2
//    center = (ta.highest(price, cycle_int) + ta.lowest(price, cycle_int)) / 2
//    forecast = center + amplitude * math.sin(phase + 2 * math.pi * periods / cycle_int)
//    forecast

forecast_price(periods) =>
    [real, imag, magnitude] = goertzel(price, cycle_length)
    phase = math.atan(imag / real)
    amplitude = (ta.highest(price, cycle_int) - ta.lowest(price, cycle_int)) / 2
    center = (ta.highest(price, cycle_int) + ta.lowest(price, cycle_int)) / 2
    
    historical_volatility = ta.stdev(price, cycle_int) / center
    
    sine_wave = amplitude * math.sin(phase + 2 * math.pi * periods / cycle_int)
    
    pattern_length = cycle_int
    pattern = true
    for i = 1 to pattern_length - 1
        if price[i] <= price[i-1]
            pattern := false
            break
    
    var forecast = 0.0
    
    if pattern
        forecast := center + sine_wave * (1 + historical_volatility * (math.random() - 0.5))
    else
        forecast := center + sine_wave * (1 - historical_volatility * (math.random() - 0.5))
    
    current_close = close
    forecast_adjusted = (forecast + current_close) / 2
    
    forecast_adjusted





