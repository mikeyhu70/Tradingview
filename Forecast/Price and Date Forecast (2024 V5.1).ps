//@version=5
indicator('Price and Date Forecast (2024 V5.1)', overlay=true,max_bars_back=5000)


// Input parameters
length1 = input.int(3, title='Dominant Cycle Length #1', minval=1)
length2 = input.int(6, title='Dominant Cycle Length #2', minval=1)
length3 = input.int(12, title='Dominant Cycle Length #3', minval=1)
length_training_mult = input.int(1, title='Multiplier for cycle training', minval=1)
use_length_weight = input.bool(false, title="Use cycle weight (higher value account for more)")
length_sf = input.bool(true, title="Shift cycle its length")
length_cycle_sf = input.float(1.0, title='# of cycle to shift', minval=0)
leftBars = input.int(12, "Left Bars to get Pivot High/Low", minval=1)
rightBars = input.int(12, "Right Bars to get Pivot High/Low", minval=1)
kp = input.int(5, title="Candlestick matching Red/Green pattern length (kp)", minval=1)
kp_start = input.int (1, title="kp start matching index 0=today, 1 = yesterday", minval=0)
kp_iteration=input.int(1,title="Max number of (kp) iterations (have to be less than kp)", minval=0)
kp_trend=input.bool(true,title="Include Up/Down candlestick pattern (kp_trend)")
kp_auto=input.bool(true,title="Auto match up/down pattern if there is no match (will nullify previous setting i.e kp_trend)")
td = input.bool(false, title="TD demark flip setup? (if not contineous bar patten in kp length)")
td_trend = input.bool(false, title="TD demark trend flip setup? (all first bars vs last bar logic)")
lookback = input.int(4, "TD Demark Lookback Flip Bars", minval=4)
y = input.int(5000, title='Lookback Bars', maxval=5000)
forecast_periods = input.int(12, title='Number of Periods to Forecast', minval=1)
_debug = input.bool(false, title="Show debug information?")

price = input.source(hl2)

txt_col_price = input.color(color.rgb(208, 227, 62), 'Text/Frame Color', group='Dashboard')
txt_col_price_adj = input.color(color.rgb(231, 37, 237), 'Text/Frame Color', group='Dashboard')
txt_col_date = input.color(color.rgb(48, 228, 241), 'Text/Frame Color', group='Dashboard')
txt_col_pattern = input.color(color.rgb(238, 232, 166), 'Text/Frame Color', group='Dashboard')
txt_col = input.color(color.rgb(182, 186, 200), 'Text/Frame Color', group='Dashboard')
dash_loc = input.string('Mid Right', 'Dashboard Location', options=['Top Right', 'Bottom Right', 'Top Left', 'Mid Left', 'Mid Right'], group='Dashboard')
text_size = input.string('Tiny', 'Dashboard Size', options=['Tiny', 'Small', 'Normal', 'Large'], group='Dashboard')
debugtext_size = input.string('Tiny', 'Debug Dashboard Size', options=['Tiny', 'Small', 'Normal', 'Large'], group='Dashboard')
debugdash_loc = input.string('Bottom Center', 'Debug Dashboard Location', options=['Top Left', 'Top Center', 'Top Right', 'Mid Left', 'Mid Center', ' Mid Right', 'Bottom Left', 'Bottom Center', 'Bottom Right'], group='Dashboard')

// ****************************************************

// Goertzel algorithm to detect the dominant cycle
goertzel(price, length) =>
    k = 0.0
    w = 2 * math.pi / length
    cosine = math.cos(w)
    sine = math.sin(w)
    coeff = 2 * cosine
    q0 = 0.0
    q1 = 0.0
    q2 = 0.0

    //_length = 2 * math.avg (length1,length2,length3)

    // Train on historical data
    // for i = 0 to 4 * length - 1

    for i = 0 to length - 1
        q0 := coeff * q1 - q2 + price[i+length_training_mult*length]
        q2 := q1
        q1 := q0


    real = (q1 - q2 * cosine)
    imag = (q2 * sine)
    magnitude = math.sqrt(real * real + imag * imag)
    [real, imag, magnitude]

