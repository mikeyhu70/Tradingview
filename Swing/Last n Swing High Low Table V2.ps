if barstate.islast
    if matrix.rows(swingHighData) >= nswing
        for i = 1 to nswing
            var int timestamp = int(matrix.get(swingHighData, i-1, 1))
            var int oneMonthAgo = int(timenow - nDatePast * 24 * 60 * 60 * 1000)
            var int sixtyDaysInFuture = int(timenow + nDateFuture * 24 * 60 * 60 * 1000)
            var int fourteenDaysInFuture = int(timenow + nNearFuture * 24 * 60 * 60 * 1000)
    
            table.cell(swingHighTable, i, 0, timestamp > oneMonthAgo ? str.format("{0,date,yyyy-MM-dd}", timestamp) : "", text_color=txt_col_bull, text_size=table_text_size)
            table.cell(swingHighTable, i, 1, str.tostring(matrix.get(swingHighData, i-1, 0)), text_color=txt_col_bull, text_size=table_text_size)

            timestamp := int(matrix.get(swingHighData, i-1, 2))
            table.cell(swingHighTable, i, 2, (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? str.format("{0,date,yyyy-MM-dd}", timestamp) : "", text_color=txt_col_bull, text_size=table_text_size, bgcolor=(timestamp >= timenow and timestamp < fourteenDaysInFuture) and (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? color.new(color.yellow, transp=80) : na)

            timestamp := int(matrix.get(swingHighData, i-1, 3))
            table.cell(swingHighTable, i, 3, (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? str.format("{0,date,yyyy-MM-dd}", timestamp) : "", text_color=txt_col_bull, text_size=table_text_size, bgcolor=timestamp >= timenow and timestamp < fourteenDaysInFuture and (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? color.new(color.yellow, transp=80): na)
    
            timestamp := int(matrix.get(swingHighData, i-1, 4))
            table.cell(swingHighTable, i, 4, (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? str.format("{0,date,yyyy-MM-dd}", timestamp) : "", text_color=txt_col_bull, text_size=table_text_size, bgcolor=timestamp >= timenow and timestamp < fourteenDaysInFuture and (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? color.new(color.yellow, transp=80): na)
    
            timestamp := int(matrix.get(swingHighData, i-1, 5))
            table.cell(swingHighTable, i, 5, (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? str.format("{0,date,yyyy-MM-dd}", timestamp) : "", text_color=txt_col_bull, text_size=table_text_size, bgcolor=timestamp >= timenow and timestamp < fourteenDaysInFuture and (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? color.new(color.yellow, transp=80) : na)
    
            timestamp := int(matrix.get(swingHighData, i-1, 6))
            table.cell(swingHighTable, i, 6, (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? str.format("{0,date,yyyy-MM-dd}", timestamp) : "", text_color=txt_col_bull, text_size=table_text_size, bgcolor=timestamp >= timenow and timestamp < fourteenDaysInFuture and (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? color.new(color.yellow, transp=80) : na)
    
            timestamp := int(matrix.get(swingHighData, i-1, 7))
            table.cell(swingHighTable, i, 7, (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? str.format("{0,date,yyyy-MM-dd}", timestamp) : "", text_color=txt_col_bull, text_size=table_text_size, bgcolor=timestamp >= timenow and timestamp < fourteenDaysInFuture and (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? color.new(color.yellow, transp=80) : na)
    
            timestamp := int(matrix.get(swingHighData, i-1, 8))
            table.cell(swingHighTable, i, 8, (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? str.format("{0,date,yyyy-MM-dd}", timestamp) : "", text_color=txt_col_bull, text_size=table_text_size, bgcolor=timestamp >= timenow and timestamp < fourteenDaysInFuture and (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? color.new(color.yellow, transp=80): na)

            timestamp := int(matrix.get(swingHighData, i-1, 9))
            table.cell(swingHighTable, i, 9, (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? str.format("{0,date,yyyy-MM-dd}", timestamp) : "", text_color=txt_col_bull, text_size=table_text_size, bgcolor=timestamp >= timenow and timestamp < fourteenDaysInFuture and (timestamp > oneMonthAgo and (not trim_date or timestamp <= sixtyDaysInFuture)) ? color.new(color.yellow, transp=80) : na)




