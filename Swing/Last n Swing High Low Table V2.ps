//@version=5
indicator("Last n Swing High Low Table 2024-V2 ", overlay = true)

// Inputs
leftBars = input.int(4, "Left Bars", minval=1)
rightBars = input.int(4, "Right Bars", minval=1)
nswing = input.int(8, "Number of Swing? Display", minval=1)
nStore= input.int(10, "Number of Swing?", minval=1)
trim_date = input.bool(true, "Trim Future Dates?")
nDatePast = input.int(45, "Number of Days in the past to display?", minval=1)
nDateFuture= input.int(90, "Number of Days in the future to display?", minval=1)
nNearFuture= input.int(21, "Number of Days in the future to change color?", minval=1)

// Get swing high and low
pivotHigh = ta.pivothigh(high, leftBars, rightBars)
pivotLow = ta.pivotlow(low, leftBars, rightBars)



txt_col_bear = input.color(color.rgb(76, 244, 169), 'Text/Frame Color', group='Dashboard')
txt_col_bull = input.color(color.rgb(228, 95, 235), 'Text/Frame Color', group='Dashboard')

txt_col = input.color(color.rgb(182, 186, 200), 'Text/Frame Color', group='Dashboard')
dash_loc_high = input.string('Top Right', 'Dashboard Location for SwingHigh', options=['Top Right', 'Bottom Right', 'Top Left', 'Mid Left', 'Mid Right'], group='Dashboard')
dash_loc_low = input.string('Bottom Right', 'Dashboard Location for SwingLow', options=['Top Right', 'Bottom Right', 'Top Left', 'Mid Left', 'Mid Right'], group='Dashboard')
dash_loc_extra = input.string('Mid Left', 'Dashboard Location for Soltice ...', options=['Top Right', 'Bottom Right', 'Top Left', 'Mid Left', 'Mid Right'], group='Dashboard')
text_size = input.string('Tiny', 'Dashboard Size', options=['Tiny', 'Small', 'Normal', 'Large'], group='Dashboard')


// Store last 10 swing high and low values
//var float[] lastHighs = array.new_float(nswing)
//var float[] lastLows = array.new_float(nswing)
//var int[] lastHighDates = array.new_int(nswing)
//var int[] lastLowDates = array.new_int(nswing)

// Declare SwingLowData as matrices
var swingLowData = matrix.new<float>(nStore, 10)

//if pivotLow
if not na(pivotLow)
    // Shift the existing rows down
    for i = nStore - 1 to 1
        for j = 0 to 9
            matrix.set(swingLowData, i, j, matrix.get(swingLowData, i - 1, j))
    
    // Add the new data to the first row
    matrix.set(swingLowData, 0, 0, low[rightBars])
    matrix.set(swingLowData, 0, 1, time[rightBars])
    matrix.set(swingLowData, 0, 2, time[rightBars] + 22.5 * 24 * 60 * 60 * 1000)
    matrix.set(swingLowData, 0, 3, time[rightBars] + 45 * 24 * 60 * 60 * 1000)
    matrix.set(swingLowData, 0, 4, time[rightBars] + 90 * 24 * 60 * 60 * 1000)
    matrix.set(swingLowData, 0, 5, time[rightBars] + 135 * 24 * 60 * 60 * 1000)
    matrix.set(swingLowData, 0, 6, time[rightBars] + 180 * 24 * 60 * 60 * 1000)
    matrix.set(swingLowData, 0, 7, time[rightBars] + 225 * 24 * 60 * 60 * 1000)
    matrix.set(swingLowData, 0, 8, time[rightBars] + 270 * 24 * 60 * 60 * 1000)
    matrix.set(swingLowData, 0, 9, time[rightBars] + 315 * 24 * 60 * 60 * 1000)

// Declare swingHighData as a matrix
var swingHighData = matrix.new<float>(nStore, 10)

// Get the current timestamp
var int currentTimestamp = time

// Initialize an empty array to store the dates
var string[] dateArrayHigh = array.new_string(0)

//if pivotHigh   
if not na (pivotHigh)
    // Shift the existing rows down
    for i = nStore - 1 to 1
        for j = 0 to 9
            matrix.set(swingHighData, i, j, matrix.get(swingHighData, i - 1, j))
    
    // Add the new data to the first row
    matrix.set(swingHighData, 0, 0, high[rightBars])
    matrix.set(swingHighData, 0, 1, time[rightBars])
    matrix.set(swingHighData, 0, 2, time[rightBars] + 22.5 * 24 * 60 * 60 * 1000)
    matrix.set(swingHighData, 0, 3, time[rightBars] + 45 * 24 * 60 * 60 * 1000)
    matrix.set(swingHighData, 0, 4, time[rightBars] + 90 * 24 * 60 * 60 * 1000)
    matrix.set(swingHighData, 0, 5, time[rightBars] + 135 * 24 * 60 * 60 * 1000)
    matrix.set(swingHighData, 0, 6, time[rightBars] + 180 * 24 * 60 * 60 * 1000)
    matrix.set(swingHighData, 0, 7, time[rightBars] + 225 * 24 * 60 * 60 * 1000)
    matrix.set(swingHighData, 0, 8, time[rightBars] + 270 * 24 * 60 * 60 * 1000)
