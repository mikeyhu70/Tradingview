var table_position_low = dash_loc_low == 'Top Left' ? position.top_left : dash_loc_low == 'Bottom Left' ? position.bottom_left : dash_loc_low == 'Top Right' ? position.top_right : dash_loc_low == 'Mid Left' ? position.middle_left : dash_loc_low == 'Mid Right' ? position.middle_right : position.bottom_right
var table_position_high = dash_loc_high == 'Top Left' ? position.top_left : dash_loc_high == 'Bottom Left' ? position.bottom_left : dash_loc_high == 'Top Right' ? position.top_right : dash_loc_high == 'Mid Left' ? position.middle_left : dash_loc_high == 'Mid Right' ? position.middle_right : position.bottom_right
var table_position_extra = dash_loc_extra == 'Top Left' ? position.top_left : dash_loc_extra == 'Bottom Left' ? position.bottom_left : dash_loc_extra == 'Top Right' ? position.top_right : dash_loc_extra == 'Mid Left' ? position.middle_left : dash_loc_extra == 'Mid Right' ? position.middle_right : position.bottom_right


var table_text_size = text_size == 'Tiny' ? size.tiny : text_size == 'Small' ? size.small : text_size == 'Normal' ? size.normal : size.large


// Create a table to display the swing high data
var table swingHighTable = table.new(position = table_position_high, rows = 10, columns = nswing+1, border_color=txt_col,border_width=1,frame_color=txt_col,frame_width=1)

table.cell(swingHighTable, 0, 0, "Date", text_color=txt_col, text_size=table_text_size,bgcolor=color.gray)
table.cell(swingHighTable, 0, 1, "High", text_color=txt_col, text_size=table_text_size,bgcolor=color.gray)
table.cell(swingHighTable, 0, 2, "Date+22.5", text_color=txt_col, text_size=table_text_size,bgcolor=color.gray)
table.cell(swingHighTable, 0, 3, "High+45", text_color=txt_col, text_size=table_text_size,bgcolor=color.gray)
