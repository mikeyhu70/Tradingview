//@version=5
indicator("Last n Swing High Low Table", overlay = true)

// Inputs
leftBars = input.int(12, "Left Bars", minval=1)
rightBars = input.int(12, "Right Bars", minval=1)
nswing = input.int(5, "Number of Swing?", minval=1)
nStore= input.int(10, "Number of Swing?", minval=1)

// Get swing high and low
pivotHigh = ta.pivothigh(high, leftBars, rightBars)
pivotLow = ta.pivotlow(low, leftBars, rightBars)
txt_col_bull = input.color(color.rgb(62, 227, 169), 'Text/Frame Color', group='Dashboard')
txt_col_bear = input.color(color.rgb(223, 17, 140), 'Text/Frame Color', group='Dashboard')
txt_col = input.color(color.rgb(182, 186, 200), 'Text/Frame Color', group='Dashboard')
dash_loc = input.string('Top Right', 'Dashboard Location', options=['Top Right', 'Bottom Right', 'Top Left', 'Bottom Left'], group='Dashboard')
text_size = input.string('Tiny', 'Dashboard Size', options=['Tiny', 'Small', 'Normal', 'Large'], group='Dashboard')


// Store last 10 swing high and low values
var float[] lastHighs = array.new_float(nswing)
var float[] lastLows = array.new_float(nswing)
var int[] lastHighDates = array.new_int(nswing)
var int[] lastLowDates = array.new_int(nswing)

if pivotHigh
    array.unshift(lastHighs, high[rightBars])
    array.unshift(lastHighDates, time[rightBars])
    if array.size(lastHighs) > nStore
        array.pop(lastHighs)
        array.pop(lastHighDates)

if pivotLow
    array.unshift(lastLows, low[rightBars])
    array.unshift(lastLowDates, time[rightBars])
    if array.size(lastLows) > nStore
        array.pop(lastLows)
        array.pop(lastLowDates)


var table_position = dash_loc == 'Top Left' ? position.top_left : dash_loc == 'Bottom Left' ? position.bottom_left : dash_loc == 'Top Right' ? position.top_right : position.bottom_right
var table_text_size = text_size == 'Tiny' ? size.tiny : text_size == 'Small' ? size.small : text_size == 'Normal' ? size.normal : size.large

// Create table
var table swingTable = table.new(table_position, 4, 11, border_color=txt_col,border_width=1,frame_color=txt_col,frame_width=1)


// Populate table
if barstate.islast
    table.cell(swingTable, 0, 0, "Date", text_color=txt_col, text_size=table_text_size)
    table.cell(swingTable, 1, 0, "Lows", text_color=txt_col, text_size=table_text_size)
    table.cell(swingTable, 2, 0, "Date", text_color=txt_col, text_size=table_text_size)
    table.cell(swingTable, 3, 0, "High", text_color=txt_col, text_size=table_text_size)

    //table.cell(swingTable, 0, 1, str.tostring(array.get(lastHighs, 0), format.mintick), bgcolor=color.white, text_size = size.tiny)
    //table.cell(swingTable, 1, 1, str.format("{0,date,yyyy-MM-dd}", array.get(lastHighDates, 0)), bgcolor=color.white, text_size = size.tiny)
    //table.cell(swingTable, 2, 1, str.tostring(array.get(lastLows, 0), format.mintick), bgcolor=color.white, text_size = size.tiny)
    //table.cell(swingTable, 3, 1, str.format("{0,date,yyyy-MM-dd}", array.get(lastLowDates, 0)), bgcolor=color.white, text_size = size.tiny)

    for i = 0 to nswing-1
        table.cell(swingTable, 0, i+1, str.format("{0,date,yyyy-MM-dd}", array.get(lastLowDates, i)), text_color=txt_col_bull, text_size=table_text_size)
        table.cell(swingTable, 1, i+1, str.tostring(array.get(lastLows,i), format.mintick), text_color=txt_col_bull, text_size=table_text_size)
        table.cell(swingTable, 2, i+1, str.format("{0,date,yyyy-MM-dd}", array.get(lastHighDates, i)), text_color=txt_col_bear, text_size=table_text_size)
        table.cell(swingTable, 3, i+1, str.tostring(array.get(lastHighs, i), format.mintick), text_color=txt_col_bear, text_size=table_text_size)
        


