    label.delete(f4[1])
    l4 := line.new(x1=n + math.min(math.round((avg_barssince_p4 - (pl4i+cyc4))-(avg_barssince_p4/4)), 500), x2=n + math.min(math.round((avg_barssince_p4 - (pl4i+cyc4))+(avg_barssince_p4/4)), 500), y1=pl4y, y2=pl4y, color=color.new(col4,ptransp))
    //l4 := line.new(x1=(n - wavelength4/8), x2=(n + wavelength4/2), y1=pl4y, y2=pl4y, color=color.new(col4,ptransp))
    line.delete(l4[1])
