// Function to get the timestamp for approximate equinox and solstice dates
getTimestamp(year, month, day) =>
    timestamp(year, month, day, 0, 0)

// Current year
currentYear = year(timenow)

// Approximate dates for equinoxes and solstices
springEquinoxMonth = 3
springEquinoxDay = 20
summerSolsticeMonth = 6
summerSolsticeDay = 21
autumnEquinoxMonth = 9
autumnEquinoxDay = 23
winterSolsticeMonth = 12
winterSolsticeDay = 21

// Calculate timestamps for the current year
spring_equinox_timestamp = getTimestamp(currentYear, springEquinoxMonth, springEquinoxDay)
summer_solstice_timestamp = getTimestamp(currentYear, summerSolsticeMonth, summerSolsticeDay)
autumn_equinox_timestamp = getTimestamp(currentYear, autumnEquinoxMonth, autumnEquinoxDay)
winter_solstice_timestamp = getTimestamp(currentYear, winterSolsticeMonth, winterSolsticeDay)

// Create a table to display the turning dates
// 4 rows for sean soltice date + max (10) * nswinhfor Gann + max (10) * nHswinh for hurst
var table gann_turning_dates = table.new(position=table_position_extra , columns=2, rows=4+nswing+10*nHswing*10, border_color=txt_col,border_width=1,frame_color=txt_col,frame_width=1)

int table_cnt = 0
int table_cnt2 = 0
int _display_low = 0
int _display_high = 0
int _display_hlow = 0
int _display_hhigh = 0
string _txt = ""

// Update the table with the turning dates
if barstate.islast 
    table.cell(gann_turning_dates, 0, 0, "Turning Date", text_color=txt_col, text_size=table_text_size)
    table.cell(gann_turning_dates, 1, 0, "Date", text_color=txt_col, text_size=table_text_size)
    table_cnt := table_cnt + 1    

    table.cell(gann_turning_dates, 0, 1, "Spring Equinox", text_color=txt_col, text_size=table_text_size)
    table.cell(gann_turning_dates, 1, 1, str.format("{0,date,yyyy-MM-dd}", spring_equinox_timestamp), text_color=txt_col, text_size=table_text_size)
    table_cnt := table_cnt + 1 

    table.cell(gann_turning_dates, 0, 2, "Summer Solstice", text_color=txt_col, text_size=table_text_size)
    table.cell(gann_turning_dates, 1, 2, str.format("{0,date,yyyy-MM-dd}", summer_solstice_timestamp), text_color=txt_col, text_size=table_text_size)
    table_cnt := table_cnt + 1     

    table.cell(gann_turning_dates, 0, 3, "Autumn Equinox", text_color=txt_col, text_size=table_text_size)
    table.cell(gann_turning_dates, 1, 3, str.format("{0,date,yyyy-MM-dd}", autumn_equinox_timestamp), text_color=txt_col, text_size=table_text_size)
    table_cnt := table_cnt + 1     

    table.cell(gann_turning_dates, 0, 4, "Winter Solstice", text_color=txt_col, text_size=table_text_size)
    table.cell(gann_turning_dates, 1, 4, str.format("{0,date,yyyy-MM-dd}", winter_solstice_timestamp), text_color=txt_col, text_size=table_text_size)
    table_cnt := table_cnt + 1    


// ====================================================================================

    //for k = 1 to nswing
    for j = 2 to 9
        _display_high := 0
        for k = 1 to nStore - 1

            var sortedSwingHighData = matrix.copy(swingHighData)
            if not sortHigh
                cellDate := matrix.get(swingHighData, k, j-1)
                cellDate0 := matrix.get(swingHighData, k, 1)
            else
                matrix.sort(sortedSwingHighData, j, order.ascending)
                cellDate := matrix.get(sortedSwingHighData, k, j-1)
                cellDate0 := matrix.get(swingHighData, k, 1)

            if (j ==3)
                _txt := "+22.5"
            else if (j == 4)
                _txt := "+45"
            else if (j == 5)
                _txt := "+90"
            else if (j == 6)
                _txt := "+135"
            else if (j == 7)
                _txt := "+180"
            else if (j == 8)
                _txt := "+225"
            else if (j == 9)
                _txt := "+270"
            else 
                _txt := "+315"
        
            if (_display_high < nswing) and (cellDate >= currentDate - nPastDaystoInclude * 86400000) and (cellDate <= fourteenDaysInFuture)
                table.cell(gann_turning_dates, 0, table_cnt+table_cnt2, "Gann H (" + str.format("{0,date,YY-MM-dd}", cellDate0) + ") " + _txt, text_color=txt_col_bear, text_size=table_text_size,bgcolor = color.new (color.gray, transp=60))
                table.cell(gann_turning_dates, 1, table_cnt+table_cnt2, str.format("{0,date,yyyy-MM-dd}", cellDate), text_color=txt_col_bear, text_size=table_text_size,bgcolor = color.new (color.gray, transp=60))
                table_cnt2 := table_cnt2 + 1 
