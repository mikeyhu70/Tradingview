    table.cell(swingHighTable, 9, 0, "+270", text_color=color.white, bgcolor=color.black,text_size=size.small)
    table.cell(swingHighTable, 10, 0, "+315", text_color=color.white, bgcolor=color.black,text_size=size.small)

    //table.cell(swingHighTable, 0, 1, str.tostring(1), text_color=color.white, bgcolor=color.black,text_size=size.small)
    //table.cell(swingHighTable, 1, 1, str.tostring(matrix.get(swingHighData, 0, 0)), text_color=color.green, bgcolor=color.black,text_size=size.small)
