    //table.cell(swingHighTable, 6, 1, str.format("{0,date,yyyy-MM-dd}",matrix.get(swingHighData, 0, 5)), text_color=color.white, bgcolor=color.black,text_size=size.small)
    //table.cell(swingHighTable, 7, 1, str.format("{0,date,yyyy-MM-dd}",matrix.get(swingHighData, 0, 6)), text_color=color.white, bgcolor=color.black,text_size=size.small)
    //table.cell(swingHighTable, 8, 1, str.format("{0,date,yyyy-MM-dd}",matrix.get(swingHighData, 0, 7)), text_color=color.white, bgcolor=color.black,text_size=size.small)
    //table.cell(swingHighTable, 9, 1, str.format("{0,date,yyyy-MM-dd}",matrix.get(swingHighData, 0, 8)), text_color=color.white, bgcolor=color.black,text_size=size.small)
    //table.cell(swingHighTable, 10, 1, str.format("{0,date,yyyy-MM-dd}",matrix.get(swingHighData, 0, 9)), text_color=color.white, bgcolor=color.black,text_size=size.small)

    //table.cell(swingHighTable, 0, 2, str.tostring(2), text_color=color.white, bgcolor=color.black)

    //Add the table rows
    for k = 0 to nStore-1
        table.cell(swingHighTable, 0,  k+1, str.tostring(k), text_color=color.red, bgcolor=color.black,text_size=size.small)
        table.cell(swingHighTable, 1,  k+1, str.tostring(matrix.get(swingHighData, k,0)), text_color=color.green, bgcolor=color.black,text_size=size.small)
        table.cell(swingHighTable, 2 , k+1 , str.format("{0,date,yyyy-MM-dd}", matrix.get(swingHighData, k,1)), text_color=color.white, bgcolor=color.black,text_size=size.small)
    
        //for j = 2 to 10
        //    table.cell(swingHighTable, j , k+1 , str.format("{0,date,yyyy-MM-dd}",matrix.get(swingHighData, k,j-1)), text_color=color.white, bgcolor=color.black,text_size=size.small)

        for j = 3 to 10
        
            cellDate := matrix.get(swingHighData, k, j-1)

            //table.cell(swingHighTable, j , k+1 , str.format("{0,date,yyyy-MM-dd}", cellDate), text_color=color.white, bgcolor=color.black,text_size=size.small)
        
            if (cellDate >= currentDate - nPastDaystoInclude * 86400000) and (cellDate <= fourteenDaysInFuture)
                table.cell(swingHighTable, j , k+1 , str.format("{0,date,yyyy-MM-dd}", cellDate), text_color=color.white, bgcolor=color.black,text_size=size.small)
            else
                table.cell(swingHighTable, j , k+1 , "", text_color=color.white, bgcolor=color.black,text_size=size.small)

            table.cell(swingHighTable, 11,  k+1, str.format("{0,date,yyyy-MM-dd}", cellDate), text_color=color.red, bgcolor=color.black,text_size=size.small)
            table.cell(swingHighTable, 12,  k+1, str.format("{0,date,yyyy-MM-dd}", currentDate), text_color=color.red, bgcolor=color.black,text_size=size.small)
            table.cell(swingHighTable, 13,  k+1, str.format("{0,date,yyyy-MM-dd}", fourteenDaysInFuture), text_color=color.red, bgcolor=color.black,text_size=size.small)
            table.cell(swingHighTable, 14,  k+1, str.tostring(k) + "," + str.tostring(j-1), text_color=color.red, bgcolor=color.black,text_size=size.small)


