var table_position_extra = dash_loc_extra == 'Top Left' ? position.top_left : dash_loc_extra == 'Bottom Left' ? position.bottom_left : dash_loc_extra == 'Top Right' ? position.top_right : dash_loc_extra == 'Mid Left' ? position.middle_left : dash_loc_extra == 'Mid Right' ? position.middle_right : position.bottom_right

var table_text_size = text_size == 'Tiny' ? size.tiny : text_size == 'Small' ? size.small : text_size == 'Normal' ? size.normal : size.large

    
currentDate = time
float cellDate = 0.0
float cellDate0 = 0.0
fourteenDaysInFuture = int(timenow + nNearFuture * 24 * 60 * 60 * 1000)

if debugHigh
    var table swingHighTable = table.new(position.bottom_right, 15, nStore + 1, border_width=1)

    // Add the table header
    table.cell(swingHighTable, 0, 0, "Row", text_color=color.white, bgcolor=color.black,text_size=size.small)
    table.cell(swingHighTable, 1, 0, "High", text_color=color.white, bgcolor=color.black,text_size=size.small)
    table.cell(swingHighTable, 2, 0, "Time", text_color=color.white, bgcolor=   color.black,text_size=size.small)
    table.cell(swingHighTable, 3, 0, "+22.5", text_color=color.white, bgcolor=color.black,text_size=size.small)
    table.cell(swingHighTable, 4, 0, "+45", text_color=color.white, bgcolor=color.black,text_size=size.small)
    table.cell(swingHighTable, 5, 0, "+90", text_color=color.white, bgcolor=color.black,text_size=size.small)
