//@version=5
indicator("Gann Hurst Pivot HL 2024-V1.2", overlay = true)

// Inputs
leftBars = input.int(6, "Left Bars Gann", minval=1)
rightBars = input.int(6, "Right Bars Gann", minval=1)
HleftBars = input.int(12, "Left Bars Hurst", minval=1)
HrightBars = input.int(12, "Right Bars Hurst", minval=1)
nswing = input.int(2, "Number of Gann Swing to Display", minval=1)
nHswing = input.int(1, "Number of Hurst Swing to Display", minval=1)
nStore= input.int(15, "Number of Swing?", minval=1)
nPastDaystoInclude = input.int(2, "Number of PAST Days to include for final output?", minval=1)
nHDatePast = input.int(3, "Number of Days in the past to include for Hurst Cycle?", minval=1)
nNearFuture= input.int(21, "Number of Days in the future to display?", minval=1)
debugHigh = input.bool(false,title="Display Debug for Gann Pivot High")
debugLow = input.bool(false,title="Display Debug for Gann Pivot Low")
HdebugHigh = input.bool(false,title="Display Debug Hurst Cycle Pivot High")
HdebugLow = input.bool(false,title="Display Debug Hurst Cycle Pivot Low")
sortHigh = input.bool(true,title="Sort Gann Pivot High Date")
sortLow = input.bool(true,title="Sort Gann Pivot Low Date")
HsortHigh = input.bool(true,title="Sort Hurst Pivot High Date")
HsortLow = input.bool(true,title="Sort Hurst Pivot Low Date")

// Get swing high and low
pivotHigh = ta.pivothigh(high, leftBars, rightBars)
pivotLow = ta.pivotlow(low, leftBars, rightBars)
HpivotHigh = ta.pivothigh(high, HleftBars, HrightBars)
HpivotLow = ta.pivotlow(low, HleftBars, HrightBars)

txt_col_bull = input.color(color.rgb(76, 244, 169), 'Text/Frame Color', group='Dashboard')
txt_col_bear = input.color(color.rgb(228, 95, 235), 'Text/Frame Color', group='Dashboard')

txt_col = input.color(color.rgb(182, 186, 200), 'Text/Frame Color', group='Dashboard')
dash_loc_extra = input.string('Top Left', 'Dashboard Location for Soltice ...', options=['Top Right', 'Bottom Right', 'Top Left', 'Mid Left', 'Mid Right'], group='Dashboard')
text_size = input.string('Tiny', 'Dashboard Size', options=['Tiny', 'Small', 'Normal', 'Large'], group='Dashboard')


// Store last 10 swing high and low values
//var float[] lastHighs = array.new_float(nswing)
//var float[] lastLows = array.new_float(nswing)
//var int[] lastHighDates = array.new_int(nswing)
//var int[] lastLowDates = array.new_int(nswing)

int daysToShift8 = 0
int daysToShift17 = 0
int daysToShift34 = 0
int daysToShift68 = 0

// ****************************************

// Declare SwingLowData as matrices
var swingLowData = matrix.new<float>(nStore, 10)
//var sortedSwingLowData = matrix.new<float>(nStore, 10, float(na))


if not na (pivotLow)
    // Shift the existing rows down
    for i = nStore - 1 to 1
        for j = 0 to 9
            matrix.set(swingLowData, i, j, matrix.get(swingLowData, i - 1, j))
    
    // Add the new data to the first row
    matrix.set(swingLowData, 0, 0, low[rightBars])
    matrix.set(swingLowData, 0, 1, time[rightBars])
    matrix.set(swingLowData, 0, 2, time[rightBars] + 22.5 * 24 * 60 * 60 * 1000)
    matrix.set(swingLowData, 0, 3, time[rightBars] + 45 * 24 * 60 * 60 * 1000)
    matrix.set(swingLowData, 0, 4, time[rightBars] + 90 * 24 * 60 * 60 * 1000)
    matrix.set(swingLowData, 0, 5, time[rightBars] + 135 * 24 * 60 * 60 * 1000)
    matrix.set(swingLowData, 0, 6, time[rightBars] + 180 * 24 * 60 * 60 * 1000)
    matrix.set(swingLowData, 0, 7, time[rightBars] + 225 * 24 * 60 * 60 * 1000)
    matrix.set(swingLowData, 0, 8, time[rightBars] + 270 * 24 * 60 * 60 * 1000)
    matrix.set(swingLowData, 0, 9, time[rightBars] + 315 * 24 * 60 * 60 * 1000)



// *****************************************

// Declare swingHighData as a matrix
//var swingHighData = matrix.new<float>(nStore, 10)

// Initialize the swingHighData matrix with the desired dimensions
var swingHighData = matrix.new<float>(nStore, 10, float(na))
//var sortedSwingHighData = matrix.new<float>(nStore, 10, float(na))


if not na(pivotHigh) 
    // Shift the existing rows down
    for i = nStore - 1 to 1
        for j = 0 to 9
            matrix.set(swingHighData, i, j, matrix.get(swingHighData, i - 1, j))
    
    // Add the new data to the first row
    matrix.set(swingHighData, 0, 0, high[rightBars])
    matrix.set(swingHighData, 0, 1, time[rightBars])
    matrix.set(swingHighData, 0, 2, time[rightBars] + 22.5 * 24 * 60 * 60 * 1000)
    matrix.set(swingHighData, 0, 3, time[rightBars] + 45 * 24 * 60 * 60 * 1000)
    matrix.set(swingHighData, 0, 4, time[rightBars] + 90 * 24 * 60 * 60 * 1000)
    matrix.set(swingHighData, 0, 5, time[rightBars] + 135 * 24 * 60 * 60 * 1000)
    matrix.set(swingHighData, 0, 6, time[rightBars] + 180 * 24 * 60 * 60 * 1000)
    matrix.set(swingHighData, 0, 7, time[rightBars] + 225 * 24 * 60 * 60 * 1000)
    matrix.set(swingHighData, 0, 8, time[rightBars] + 270 * 24 * 60 * 60 * 1000)
    matrix.set(swingHighData, 0, 9, time[rightBars] + 315 * 24 * 60 * 60 * 1000) 

// *********************************

// Declare SwingLowData as matrices
var HswingLowData = matrix.new<float>(nStore, 10)
//var HsortedSwingLowData = matrix.new<float>(nStore, 10, float(na))

if not na (HpivotLow)
    // Shift the existing rows down
    for i = nStore - 1 to 1
        for j = 0 to 9
            matrix.set(HswingLowData, i, j, matrix.get(HswingLowData, i - 1, j))

    // Calculate the number of days to shift for each cycle
    while time[HrightBars] + daysToShift8 * 24 * 60 * 60 * 1000 < timenow - nHDatePast * 24 * 60 * 60 * 1000
        daysToShift8 += 8

    while time[HrightBars] + daysToShift17 * 24 * 60 * 60 * 1000 < timenow - nHDatePast * 24 * 60 * 60 * 1000
        daysToShift17 += 17

    while time[HrightBars] + daysToShift34 * 24 * 60 * 60 * 1000 < timenow - nHDatePast * 24 * 60 * 60 * 1000
        daysToShift34 += 34

    while time[HrightBars] + daysToShift68 * 24 * 60 * 60 * 1000 < timenow - nHDatePast * 24 * 60 * 60 * 1000
        daysToShift68 += 68
    
    // Add the new data to the first row
    matrix.set(HswingLowData, 0, 0, low[HrightBars])
    matrix.set(HswingLowData, 0, 1, time[HrightBars])
    matrix.set(HswingLowData, 0, 2, time[HrightBars] + 8 * 24 * 60 * 60 * 1000)
    //matrix.set(HswingLowData, 0, 2, time[HrightBars] + daysToShift8 * 24 * 60 * 60 * 1000)
    //matrix.set(HswingLowData, 0, 3, time[HrightBars] + 17 * 24 * 60 * 60 * 1000)
    matrix.set(HswingLowData, 0, 3, time[HrightBars] + daysToShift17 * 24 * 60 * 60 * 1000)
    //matrix.set(HswingLowData, 0, 4, time[HrightBars] + 34 * 24 * 60 * 60 * 1000)
    matrix.set(HswingLowData, 0, 4, time[HrightBars] + daysToShift34 * 24 * 60 * 60 * 1000)
    //matrix.set(HswingLowData, 0, 5, time[HrightBars] + 68 * 24 * 60 * 60 * 1000)
    matrix.set(HswingLowData, 0, 5, time[HrightBars] + daysToShift68 * 24 * 60 * 60 * 1000)
    matrix.set(HswingLowData, 0, 6, time[HrightBars] + 136 * 24 * 60 * 60 * 1000)
    matrix.set(HswingLowData, 0, 7, time[HrightBars] + 273 * 24 * 60 * 60 * 1000)
    matrix.set(HswingLowData, 0, 8, time[HrightBars] + 546 * 24 * 60 * 60 * 1000)
    matrix.set(HswingLowData, 0, 9, time[HrightBars] + 1637 * 24 * 60 * 60 * 1000)


// ***********************************

// Declare swingHighData as a matrix
//var swingHighData = matrix.new<float>(nStore, 10)

// Initialize the swingHighData matrix with the desired dimensions
var HswingHighData = matrix.new<float>(nStore, 10, float(na))
//var HsortedSwingHighData = matrix.new<float>(nStore, 10, float(na))


if not na(HpivotHigh) 
    // Shift the existing rows down
    for i = nStore - 1 to 1
        for j = 0 to 9
            matrix.set(HswingHighData, i, j, matrix.get(HswingHighData, i - 1, j))

    // Calculate the number of days to shift for each cycle
    while time[HrightBars] + daysToShift8 * 24 * 60 * 60 * 1000 < timenow - nHDatePast * 24 * 60 * 60 * 1000
        daysToShift8 += 8

    while time[HrightBars] + daysToShift17 * 24 * 60 * 60 * 1000 < timenow - nHDatePast * 24 * 60 * 60 * 1000
        daysToShift17 += 17

    while time[HrightBars] + daysToShift34 * 24 * 60 * 60 * 1000 < timenow - nHDatePast * 24 * 60 * 60 * 1000
        daysToShift34 += 34

    while time[HrightBars] + daysToShift68 * 24 * 60 * 60 * 1000 < timenow - nHDatePast * 24 * 60 * 60 * 1000
        daysToShift68 += 68
    
    // Add the new data to the first row
    matrix.set(HswingHighData, 0, 0, high[HrightBars])
    matrix.set(HswingHighData, 0, 1, time[HrightBars])
    //matrix.set(HswingHighData, 0, 2, time[HrightBars] + daysToShift8 * 24 * 60 * 60 * 1000)
    matrix.set(HswingHighData, 0, 2, time[HrightBars] + 8 * 24 * 60 * 60 * 1000)
    matrix.set(HswingHighData, 0, 3, time[HrightBars] + daysToShift17 * 24 * 60 * 60 * 1000)
    //matrix.set(HswingHighData, 0, 3, time[HrightBars] + 17 * 24 * 60 * 60 * 1000)
    matrix.set(HswingHighData, 0, 4, time[HrightBars] + daysToShift34 * 24 * 60 * 60 * 1000)
    //matrix.set(HswingHighData, 0, 4, time[HrightBars] + 34 * 24 * 60 * 60 * 1000)
    matrix.set(HswingHighData, 0, 5, time[HrightBars] + daysToShift68 * 24 * 60 * 60 * 1000)
    //matrix.set(HswingHighData, 0, 5, time[HrightBars] + 68 * 24 * 60 * 60 * 1000)
    matrix.set(HswingHighData, 0, 6, time[HrightBars] + 136 * 24 * 60 * 60 * 1000)
    matrix.set(HswingHighData, 0, 7, time[HrightBars] + 273 * 24 * 60 * 60 * 1000)
    matrix.set(HswingHighData, 0, 8, time[HrightBars] + 546 * 24 * 60 * 60 * 1000)
    matrix.set(HswingHighData, 0, 9, time[HrightBars] + 1637 * 24 * 60 * 60 * 1000)


// Create table
